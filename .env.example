# ============================================
# 环境变量 · Environment Variables
# ============================================
# 复制本文件为 .env 并填入真实的值
# 注意：.env 文件不提交到 Git！

# ---------- MongoDB 数据库 ----------
# 连接字符串 · 从 MongoDB Atlas 获取
# 格式：mongodb+srv://<用户名>:<密码>@<集群>.mongodb.net/<数据库名>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxx.mongodb.net/hou-xiaowen?retryWrites=true&w=majority

# ---------- 站点配置 ----------
# 站点名称（中英文可选
SITE_TITLE=侯小雯 · Wonderland
SITE_URL=https://your-domain.vercel.app

# ---------- 功能开关（可选） ----------
# 博客文章是否显示
ENABLE_BLOG=true

# 作品集是否启用
ENABLE_PORTFOLIO=true

# 画册是否启用
ENABLE_GALLERY=true

# 照片元数据管理
ENABLE_PHOTOS_API=true
