{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/photos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|jpg|jpeg|png|gif|webp|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/portfolio", "destination": "/portfolio.html" },
    { "source": "/gallery", "destination": "/gallery.html" },
    { "source": "/me", "destination": "/me.html" },
    { "source": "/en", "destination": "/index-en.html" },
    { "source": "/en/blog", "destination": "/blog-en.html" },
    { "source": "/en/portfolio", "destination": "/portfolio-en.html" },
    { "source": "/en/gallery", "destination": "/gallery-en.html" },
    { "source": "/en/me", "destination": "/me-en.html" }
  ]
}
